{
  "info": {
    "_postman_id": "a2f2c8f4-7f4f-4d1a-ae7e-9f5d3a2b0f0c",
    "name": "RidePack API - Vehicle (Car Details)",
    "description": "Postman collection for RidePack vehicle endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "protocol", "value": "http" },
    { "key": "host", "value": "localhost" },
    { "key": "port", "value": "3000" },
    { "key": "token", "value": "" },
    { "key": "vehicleId", "value": "" }
  ],
  "item": [
    {
      "name": "1) Add Vehicle (POST /api/vehicles)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"category\": \"car\",\n  \"brand\": \"Toyota\",\n  \"model\": \"Camry\",\n  \"color\": \"Black\",\n  \"registrationNumber\": \"ab-12345\",\n  \"confirmation\": true\n}\n",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{protocol}}://{{host}}:{{port}}/api/vehicles",
          "protocol": "{{protocol}}",
          "host": ["{{host}}"],
          "port": "{{port}}",
          "path": ["api", "vehicles"]
        }
      }
    },
    {
      "name": "2) Get My Vehicles (GET /api/vehicles)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": {
          "raw": "{{protocol}}://{{host}}:{{port}}/api/vehicles",
          "protocol": "{{protocol}}",
          "host": ["{{host}}"],
          "port": "{{port}}",
          "path": ["api", "vehicles"]
        }
      }
    },
    {
      "name": "3) Get Vehicle By ID (GET /api/vehicles/:id)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": {
          "raw": "{{protocol}}://{{host}}:{{port}}/api/vehicles/{{vehicleId}}",
          "protocol": "{{protocol}}",
          "host": ["{{host}}"],
          "port": "{{port}}",
          "path": ["api", "vehicles", "{{vehicleId}}"]
        }
      }
    },
    {
      "name": "4) Update Vehicle (PUT /api/vehicles/:id)",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"color\": \"White\"\n}\n",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{protocol}}://{{host}}:{{port}}/api/vehicles/{{vehicleId}}",
          "protocol": "{{protocol}}",
          "host": ["{{host}}"],
          "port": "{{port}}",
          "path": ["api", "vehicles", "{{vehicleId}}"]
        }
      }
    },
    {
      "name": "5) Delete Vehicle (DELETE /api/vehicles/:id - soft delete)",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": {
          "raw": "{{protocol}}://{{host}}:{{port}}/api/vehicles/{{vehicleId}}",
          "protocol": "{{protocol}}",
          "host": ["{{host}}"],
          "port": "{{port}}",
          "path": ["api", "vehicles", "{{vehicleId}}"]
        }
      }
    }
  ]
}

