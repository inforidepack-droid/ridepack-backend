{
  "info": {
    "_postman_id": "a2f2c8f4-7f4f-4d1a-ae7e-9f5d3a2b0f0c",
    "name": "RidePack API",
    "description": "RidePack parcel marketplace backend.\n\n**Phone OTP:** In **development** (`NODE_ENV=development`), OTP is fixed **`1234`**, no WhatsApp/SMS is sent, and **`POST /api/auth/verify-otp`** accepts `1234` without calling **`send-otp`** first.\n\nIn **non-development**, **`POST /api/auth/send-otp`** may deliver the same 4-digit code via **Twilio WhatsApp** and/or **SMS** when each channel is configured; **503** if neither channel is configured. Use the code from WhatsApp or SMS in **`verify-otp`**.\n\nFor more endpoints, see **`api.http`** in the repo root (REST Client).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "protocol", "value": "http" },
    { "key": "host", "value": "localhost" },
    { "key": "port", "value": "3000" },
    { "key": "accessToken", "value": "" },
    { "key": "adminAccessToken", "value": "" },
    { "key": "token", "value": "" },
    { "key": "vehicleId", "value": "" },
    { "key": "bookingId", "value": "" },
    { "key": "rideId", "value": "" },
    { "key": "tripId", "value": "" },
    { "key": "notificationId", "value": "" },
    { "key": "riderUserId", "value": "" },
    { "key": "reviewId", "value": "" },
    { "key": "walletTxId", "value": "" },
    { "key": "walletInternalSecret", "value": "" },
    { "key": "veriffWebhookSignature", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "description": "OTP delivery in production/staging: WhatsApp and/or SMS (Twilio). At least one must be configured.",
      "item": [
        {
          "name": "Send OTP — India (+ countryCode)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"countryCode\": \"+91\",\n  \"phoneNumber\": \"8146260465\"\n}\n",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{protocol}}://{{host}}:{{port}}/api/auth/send-otp",
              "protocol": "{{protocol}}",
              "host": ["{{host}}"],
              "port": "{{port}}",
              "path": ["api", "auth", "send-otp"]
            }
          }
        },
        {
          "name": "Send OTP — US (+1)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"countryCode\": \"+1\",\n  \"phoneNumber\": \"2025551234\"\n}\n",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{protocol}}://{{host}}:{{port}}/api/auth/send-otp",
              "protocol": "{{protocol}}",
              "host": ["{{host}}"],
              "port": "{{port}}",
              "path": ["api", "auth", "send-otp"]
            }
          }
        },
        {
          "name": "Send OTP — E.164 phoneNumber only",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"+918146260465\"\n}\n",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{protocol}}://{{host}}:{{port}}/api/auth/send-otp",
              "protocol": "{{protocol}}",
              "host": ["{{host}}"],
              "port": "{{port}}",
              "path": ["api", "auth", "send-otp"]
            }
          }
        },
        {
          "name": "Verify OTP — countryCode + phone",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"countryCode\": \"+91\",\n  \"phoneNumber\": \"8146260465\",\n  \"otp\": \"1234\"\n}\n",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{protocol}}://{{host}}:{{port}}/api/auth/verify-otp",
              "protocol": "{{protocol}}",
              "host": ["{{host}}"],
              "port": "{{port}}",
              "path": ["api", "auth", "verify-otp"]
            }
          }
        },
        {
          "name": "Verify OTP — with FCM (optional)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"countryCode\": \"+91\",\n  \"phoneNumber\": \"8146260465\",\n  \"otp\": \"1234\",\n  \"fcmToken\": \"fcm-device-token-from-react-native\",\n  \"deviceType\": \"android\"\n}\n",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{protocol}}://{{host}}:{{port}}/api/auth/verify-otp",
              "protocol": "{{protocol}}",
              "host": ["{{host}}"],
              "port": "{{port}}",
              "path": ["api", "auth", "verify-otp"]
            }
          }
        },
        {
          "name": "Verify OTP — E.164 phoneNumber only",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"+918146260465\",\n  \"otp\": \"1234\"\n}\n",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{protocol}}://{{host}}:{{port}}/api/auth/verify-otp",
              "protocol": "{{protocol}}",
              "host": ["{{host}}"],
              "port": "{{port}}",
              "path": ["api", "auth", "verify-otp"]
            }
          }
        },
        {
          "name": "Google Sign-In",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idToken\": \"YOUR_GOOGLE_ID_TOKEN_FROM_MOBILE_APP\"\n}\n",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{protocol}}://{{host}}:{{port}}/api/auth/google",
              "protocol": "{{protocol}}",
              "host": ["{{host}}"],
              "port": "{{port}}",
              "path": ["api", "auth", "google"]
            }
          }
        }
      ]
    },
    {
      "name": "Vehicles",
      "description": "Rider JWT: use collection variable `token` or `accessToken` in Authorization header.",
      "item": [
        {
          "name": "Add Vehicle (POST /api/vehicles)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"category\": \"car\",\n  \"brand\": \"Toyota\",\n  \"model\": \"Camry\",\n  \"color\": \"Black\",\n  \"registrationNumber\": \"ab-12345\",\n  \"confirmation\": true\n}\n",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{protocol}}://{{host}}:{{port}}/api/vehicles",
              "protocol": "{{protocol}}",
              "host": ["{{host}}"],
              "port": "{{port}}",
              "path": ["api", "vehicles"]
            }
          }
        },
        {
          "name": "Get My Vehicles (GET /api/vehicles)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{protocol}}://{{host}}:{{port}}/api/vehicles",
              "protocol": "{{protocol}}",
              "host": ["{{host}}"],
              "port": "{{port}}",
              "path": ["api", "vehicles"]
            }
          }
        },
        {
          "name": "Get Vehicle By ID (GET /api/vehicles/:id)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{protocol}}://{{host}}:{{port}}/api/vehicles/{{vehicleId}}",
              "protocol": "{{protocol}}",
              "host": ["{{host}}"],
              "port": "{{port}}",
              "path": ["api", "vehicles", "{{vehicleId}}"]
            }
          }
        },
        {
          "name": "Update Vehicle (PUT /api/vehicles/:id)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"color\": \"White\"\n}\n",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{protocol}}://{{host}}:{{port}}/api/vehicles/{{vehicleId}}",
              "protocol": "{{protocol}}",
              "host": ["{{host}}"],
              "port": "{{port}}",
              "path": ["api", "vehicles", "{{vehicleId}}"]
            }
          }
        },
        {
          "name": "Delete Vehicle (DELETE /api/vehicles/:id - soft delete)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{protocol}}://{{host}}:{{port}}/api/vehicles/{{vehicleId}}",
              "protocol": "{{protocol}}",
              "host": ["{{host}}"],
              "port": "{{port}}",
              "path": ["api", "vehicles", "{{vehicleId}}"]
            }
          }
        }
      ]
    }
  ]
}
